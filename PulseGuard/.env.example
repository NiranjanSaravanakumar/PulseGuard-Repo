# ── MongoDB connection ────────────────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
MONGO_DB=pulseguard

# ── Simulator ─────────────────────────────────────────────────────────────────
# Base URL of the FastAPI backend the simulator will POST data to
API_URL=http://localhost:8000

# Seconds between each sensor reading (per thread)
SIMULATOR_INTERVAL=2
